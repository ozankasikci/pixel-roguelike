root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[*.py]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2
